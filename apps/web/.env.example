# Optional override. Relative paths resolve from apps/web when running Next.
# COSTLENS_DATABASE_PATH=../../data/costlens.db

# When set, GET/POST /api/poll requires Authorization: Bearer <secret> or x-costlens-secret: <secret>
# COSTLENS_POLL_SECRET=

# --- Collector credentials (server-side only; collectors return [] when unset) ---
# Default `runCollectors()` uses Vercel + Neon only. Pass `openaiCollector` / `anthropicCollector` in `collectors` to include OpenAI / Anthropic.
# Vercel: team-scoped token for REST. Optional explicit team id if the token has multiple teams.
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=

# OpenAI: organization admin key for /v1/organization/usage/completions.
# Prefer OPENAI_ADMIN_KEY; OPENAI_API_KEY is accepted as a fallback (same key material).
# OPENAI_ADMIN_KEY=
# OPENAI_API_KEY=

# Anthropic: organization admin key (sk-ant-admin…) for Usage & Cost admin APIs.
# Prefer ANTHROPIC_ADMIN_KEY; ANTHROPIC_API_KEY is accepted as a fallback.
# ANTHROPIC_ADMIN_KEY=
# ANTHROPIC_API_KEY=
